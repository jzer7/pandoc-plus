# Project Configuration for CI/CD
# This file contains shared configuration values used across different CI/CD workflows
# and build tools to ensure consistency and easier maintenance.

# Image configuration
IMAGE_NAME=jzer7/pandoc-plus
REGISTRY=ghcr.io
BASE_IMAGE=pandoc/latex:3.7-ubuntu

# Build configuration
PLATFORMS=linux/amd64,linux/arm64
DOCKER_BUILDKIT=1
BUILD_ARGS=BUILDKIT_INLINE_CACHE=1

# Test configuration
TEST_FILES=test.md tests/sample.md

# LaTeX packages to install
LATEX_PACKAGES=enumitem moderncv sectsty underscore lastpage

# System packages to install
SYSTEM_PACKAGES=make unzip wget
